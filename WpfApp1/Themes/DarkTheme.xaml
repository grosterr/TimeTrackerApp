<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#252526"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2D2D30"/>
    <SolidColorBrush x:Key="OverlayBackgroundBrush" Color="#3E3E42"/>
    
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#AAAAAA"/>
    
    <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
