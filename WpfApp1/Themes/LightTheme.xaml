<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F7F7F5"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="OverlayBackgroundBrush" Color="#F1F1F1"/>
    
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#333333"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#777777"/>
    
    <SolidColorBrush x:Key="BorderBrush" Color="#EEEEEE"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#E5E5E5"/>
    
</ResourceDictionary>
