<UserControl x:Class="WpfApp1.Views.TaskEditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Введіть заголовок..." FontSize="24" FontWeight="Bold" Foreground="{DynamicResource SecondaryTextBrush}" Margin="2,0,0,0" IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=TitleBox}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Text, ElementName=TitleBox}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBox x:Name="TitleBox"
                     Text="{Binding TaskTitle, UpdateSourceTrigger=PropertyChanged}" 
                     IsReadOnly="{Binding IsReadOnly}"
                     FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"
                     BorderThickness="0,0,0,1" Background="Transparent"/>
        </Grid>

        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <CheckBox Content="🎯 Це задача (встановити дедлайн та час)" 
                          IsChecked="{Binding IsTask}" 
                          IsEnabled="{Binding IsEditMode}"
                          FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,15,0"/>
                
                <CheckBox Content="🔄 Повторювана задача" 
                          IsChecked="{Binding IsRecurring}" 
                          IsEnabled="{Binding IsEditMode}"
                          FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                          
                <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRecurring}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Кожні" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Text="{Binding RecurrenceIntervalDays, UpdateSourceTrigger=PropertyChanged}" Width="30" TextAlignment="Center" Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}" BorderThickness="0,0,0,1" IsEnabled="{Binding IsEditMode}"/>
                    <TextBlock Text="днів" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Статус:" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,2"></TextBlock>
                    <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding Status}" IsEnabled="{Binding IsEditMode}" Height="35">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="10,2" Background="{DynamicResource PanelBackgroundBrush}">
                                    <TextBlock Text="{Binding}" FontSize="12" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                    <TextBlock Text="Пріоритет:" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,2"></TextBlock>
                    <ComboBox ItemsSource="{Binding Priorities}" SelectedItem="{Binding Priority}" IsEnabled="{Binding IsEditMode}" Height="35" Margin="0,0,0,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="10,2" Background="{DynamicResource PanelBackgroundBrush}">
                                    <TextBlock Text="{Binding}" FontSize="12" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                    <TextBlock Text="Колір:" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,2"/>
                    <ComboBox ItemsSource="{Binding AvailableColors}" 
                              SelectedValuePath="Hex" 
                              SelectedValue="{Binding CustomColor}" 
                              IsEnabled="{Binding IsEditMode}" Height="35">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="14" Height="14" Background="{Binding Hex, TargetNullValue=Transparent}" 
                                            CornerRadius="3" Margin="0,0,8,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                    <TextBlock Text="{Binding Name}" FontSize="12" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <Grid Margin="0,15,0,0">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTask}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Дедлайн (Дата):" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,2"/>
                    <DatePicker SelectedDate="{Binding DeadTime}" 
                                IsEnabled="{Binding IsEditMode}" 
                                BorderThickness="0,0,0,1" Background="Transparent"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                    <TextBlock Text="Час (ГГ:ХХ):" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding StartTimeStr, UpdateSourceTrigger=PropertyChanged}" 
                             IsReadOnly="{Binding IsReadOnly}" MaxLength="5" Foreground="{DynamicResource PrimaryTextBrush}"
                             BorderThickness="0,0,0,1" Background="Transparent" FontSize="14" Padding="0,2"/>

                    <CheckBox Content="🔒 Зафіксувати час" IsChecked="{Binding IsTimeLocked}" 
                              IsEnabled="{Binding IsEditMode}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,0" 
                              ToolTip="Якщо увімкнено, задача не буде автоматично зсуватися таймером"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                    <TextBlock Text="Оцінка (у хв):" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding EstimatedMinutesStr, UpdateSourceTrigger=PropertyChanged}" 
                             IsReadOnly="{Binding IsReadOnly}" Foreground="{DynamicResource PrimaryTextBrush}"
                             BorderThickness="0,0,0,1" Background="Transparent" FontSize="14" Padding="0,2"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Теги:" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,5"/>
            <WrapPanel>
                <ItemsControl ItemsSource="{Binding TaskTags}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource OverlayBackgroundBrush}" CornerRadius="12" Padding="10,4" Margin="0,0,5,5">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12" VerticalAlignment="Center"/>
                                    <Button Content="×" Command="{Binding DataContext.RemoveTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="Bold" Margin="5,0,0,0" Cursor="Hand"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,5" IsEnabled="{Binding IsEditMode}">
                    <TextBox Text="{Binding NewTagText, UpdateSourceTrigger=PropertyChanged}" Width="100" Height="24" Padding="5,2" Margin="0,0,5,0" BorderThickness="0,0,0,1" Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12"/>
                    <Button Command="{Binding AddTagCommand}" Width="24" Height="24" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Border Background="#4A90E2" CornerRadius="12" Width="24" Height="24">
                            <TextBlock Text="+" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                        </Border>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </StackPanel>

        <Grid Grid.Row="3">
            <TextBlock Text="Введіть опис нотатки..." FontSize="16" Foreground="{DynamicResource SecondaryTextBrush}" Margin="2,2,0,0" IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=DescBox}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Text, ElementName=DescBox}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBox x:Name="DescBox"
                     Text="{Binding TaskDescription, UpdateSourceTrigger=PropertyChanged}" 
                     IsReadOnly="{Binding IsReadOnly}"
                     TextWrapping="Wrap" AcceptsReturn="True" FontSize="16" 
                     BorderThickness="0" Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}"
                     VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <Button Grid.Row="4" 
                Content="ЗБЕРЕГТИ" 
                Command="{Binding SaveCommand}" 
                HorizontalAlignment="Right" Width="120" Height="35" 
                Margin="0,15,0,0" Background="#4A90E2" Foreground="White" 
                FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
        <Button Grid.Row="4" 
            Content="РЕДАГУВАТИ" 
            Command="{Binding EditCommand}" 
            HorizontalAlignment="Right" Width="120" Height="35" 
            Margin="0,15,138,0" Background="#FF4AE28B" Foreground="White" 
            FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
        <Button Grid.Row="4" 
            Content="ВИДАЛИТИ" 
            Command="{Binding DeleteCommand}" 
            HorizontalAlignment="Right" Width="120" Height="35" 
            Margin="0,15,274,0" Background="#FFE24A4A" Foreground="White" 
            FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
    </Grid>
</UserControl>