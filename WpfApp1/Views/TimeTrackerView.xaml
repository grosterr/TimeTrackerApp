<UserControl x:Class="WpfApp1.Views.TimeTrackerView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Views"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Оберіть задачу для трекінгу часу:" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10"/>
                <ComboBox ItemsSource="{Binding AvailableTasks}" 
                          SelectedItem="{Binding SelectedTask}" 
                          DisplayMemberPath="Title"
                          FontSize="16" Padding="5" Height="40" Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="{Binding TaskProgressInfo}" Foreground="{DynamicResource AccentBrush}" FontSize="14" Margin="0,10,0,0" FontWeight="SemiBold"/>
            </StackPanel>

            <Border Grid.Row="1" Margin="0,15,0,10" CornerRadius="12" Padding="16,12"
                    BorderThickness="1.5">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#FFF5F0"/>
                        <Setter Property="BorderBrush" Value="#E8CCBB"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPomodoroEnabled}" Value="True">
                                <Setter Property="Background" Value="#FFF0E8"/>
                                <Setter Property="BorderBrush" Value="#E74C3C"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding TogglePomodoroCommand}"
                            Width="42" Height="42" BorderThickness="0" Cursor="Hand"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="btnBorder" CornerRadius="21" 
                                                    Width="42" Height="42" 
                                                    Background="#E74C3C" Cursor="Hand">
                                                <TextBlock Text="🍅" FontSize="20" 
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsPomodoroEnabled}" Value="False">
                                                    <Setter TargetName="btnBorder" Property="Background" Value="#CCCCCC"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="btnBorder" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ПОМОДОРО" FontWeight="Bold" FontSize="13" Foreground="#C0392B" VerticalAlignment="Center"/>
                            <TextBlock Text=" · " Foreground="{DynamicResource SecondaryTextBrush}" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding PomodoroPhaseText}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PomodoroPhaseText}" Value="КОРОТКА ПЕРЕРВА">
                                                <Setter Property="Foreground" Value="#27AE60"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PomodoroPhaseText}" Value="ДОВГА ПЕРЕРВА">
                                                <Setter Property="Foreground" Value="#2980B9"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Text="{Binding PomodoroStatusText}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="2" CornerRadius="8" Padding="12,6" Margin="10,0,0,0"
                            VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#FDEDEA"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPomodoroEnabled}" Value="False">
                                        <Setter Property="Background" Value="#EEEEEE"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding PomodoroPhaseIcon}" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding PomodoroTimeDisplay}" FontSize="22" FontWeight="Bold" 
                                       FontFamily="Consolas" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#C0392B"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPomodoroEnabled}" Value="False">
                                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="ЗАЛИШИЛОСЬ ЧАСУ" FontSize="14" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Viewbox MaxHeight="160">
                        <TextBlock Text="{Binding CurrentTimeDisplay}" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" FontFamily="Consolas"/>
                    </Viewbox>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="▶ СТАРТ" Command="{Binding StartCommand}"
                        Width="140" Height="50" Background="#FF4AE28B" Foreground="White" 
                        FontSize="16" FontWeight="Bold" BorderThickness="0" Margin="10" Cursor="Hand"/>
                <Button Content="⏸ ПАУЗА" Command="{Binding PauseCommand}" 
                        Width="140" Height="50" Background="#F5A623" Foreground="White" 
                        FontSize="16" FontWeight="Bold" BorderThickness="0" Margin="10" Cursor="Hand"/>
                <Button Content="⏹ СТОП І ЗБЕРЕГТИ" Command="{Binding StopCommand}" 
                        Width="200" Height="50" Background="#E74C3C" Foreground="White" 
                        FontSize="16" FontWeight="Bold" BorderThickness="0" Margin="10" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <Grid Background="{DynamicResource OverlayBackgroundBrush}" Visibility="{Binding IsTimeUpPanelVisible, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource PanelBackgroundBrush}" Width="450" Height="280" VerticalAlignment="Center" HorizontalAlignment="Center" 
                    CornerRadius="15" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="25" ShadowDepth="5"/>
                </Border.Effect>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                    <TextBlock Text="⏰ ЧАС ВИЙШОВ!" FontSize="28" FontWeight="Bold" Foreground="#E74C3C" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Бажаєте продовжити час виконання?" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Text="(Наступні незафіксовані задачі будуть автоматично зсунуті в календарі)" 
                               TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,5,0,25"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="+ 5 хв" Command="{Binding ExtendCommand}" CommandParameter="5" 
                                Width="100" Height="45" Background="#4A90E2" Foreground="White" FontWeight="Bold" FontSize="14" Margin="5" BorderThickness="0" Cursor="Hand"/>
                        <Button Content="+ 15 хв" Command="{Binding ExtendCommand}" CommandParameter="15" 
                                Width="100" Height="45" Background="#4A90E2" Foreground="White" FontWeight="Bold" FontSize="14" Margin="5" BorderThickness="0" Cursor="Hand"/>
                        <Button Content="ЗАВЕРШИТИ" Command="{Binding FinishCommand}" 
                                Width="120" Height="45" Background="#E74C3C" Foreground="White" FontWeight="Bold" FontSize="14" Margin="15,5,5,5" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>