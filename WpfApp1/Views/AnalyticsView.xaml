<UserControl x:Class="WpfApp1.Views.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:core="clr-namespace:WpfApp1.Core"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900"
             Background="Transparent">

    <UserControl.Resources>
        <core:PercentToWidthConverter x:Key="PctToWidth"/>

        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PeriodButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource OverlayBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="24,20">
        <StackPanel MaxWidth="860">

            <TextBlock Text="📊 Аналітика" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,20"/>
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="Дашборд продуктивності" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,14"/>

                    <WrapPanel>
                        <Border Style="{StaticResource StatusCard}">
                            <StackPanel>
                                <TextBlock Text="{Binding TotalTasks}" FontSize="28" FontWeight="Bold" Foreground="#3B82F6"/>
                                <TextBlock Text="Всього задач" FontSize="11" Foreground="#6B7280" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatusCard}">
                            <StackPanel>
                                <TextBlock Text="{Binding TodoCount}" FontSize="28" FontWeight="Bold" Foreground="#6B7280"/>
                                <TextBlock Text="To-Do" FontSize="11" Foreground="#6B7280" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatusCard}">
                            <StackPanel>
                                <TextBlock Text="{Binding InProgressCount}" FontSize="28" FontWeight="Bold" Foreground="#F59E0B"/>
                                <TextBlock Text="В процесі" FontSize="11" Foreground="#6B7280" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatusCard}">
                            <StackPanel>
                                <TextBlock Text="{Binding DoneCount}" FontSize="28" FontWeight="Bold" Foreground="#10B981"/>
                                <TextBlock Text="Виконано" FontSize="11" Foreground="#6B7280" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatusCard}">
                            <StackPanel>
                                <TextBlock Text="{Binding BlockedCount}" FontSize="28" FontWeight="Bold" Foreground="#EF4444"/>
                                <TextBlock Text="Заблоковано" FontSize="11" Foreground="#6B7280" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <StackPanel Margin="0,16,0,0">
                        <DockPanel>
                            <TextBlock Text="Загальний прогрес" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" DockPanel.Dock="Left"/>
                            <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" FontSize="12" FontWeight="Bold" Foreground="#10B981"
                                       Text="{Binding CompletionPercent, StringFormat={}{0}%}"/>
                        </DockPanel>
                        <Border x:Name="ProgressBarTrack" Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="5" Height="10" Margin="0,6,0,0">
                            <Border Background="#10B981" CornerRadius="5" HorizontalAlignment="Left">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource PctToWidth}">
                                        <Binding Path="CompletionPercent"/>
                                        <Binding Path="ActualWidth" ElementName="ProgressBarTrack"/>
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Витрачений час" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,2,0,0">
                                <Run Text="Всього: "/>
                                <Run Text="{Binding TotalTimeFormatted, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <Button Content="Тиждень" Style="{StaticResource PeriodButton}" 
                                    Command="{Binding SetPeriodCommand}" CommandParameter="Тиждень" Margin="0,0,4,0"/>
                            <Button Content="Місяць" Style="{StaticResource PeriodButton}" 
                                    Command="{Binding SetPeriodCommand}" CommandParameter="Місяць"/>
                        </StackPanel>
                    </DockPanel>

                    <ItemsControl ItemsSource="{Binding TimePerDayBars}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                    <Border x:Name="TimeDayTrack" Grid.Column="1" Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="4" Height="20" Margin="6,0">
                                        <Border CornerRadius="4" HorizontalAlignment="Left" MinWidth="2">
                                            <Border.Background>
                                                <SolidColorBrush Color="#5B8DEF"/>
                                            </Border.Background>
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource PctToWidth}">
                                                    <Binding Path="Percentage"/>
                                                    <Binding Path="ActualWidth" ElementName="TimeDayTrack"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding DisplayValue}" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}" 
                                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="Виконання за категоріями" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12"/>

                    <ItemsControl ItemsSource="{Binding CompletionByCategory}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <DockPanel>
                                        <TextBlock Text="{Binding Label}" FontSize="12" Foreground="{DynamicResource PrimaryTextBrush}" DockPanel.Dock="Left" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding DisplayValue}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" 
                                                   DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                                    </DockPanel>
                                    <Border x:Name="CatTrack" Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="4" Height="14" Margin="0,4,0,0">
                                        <Border CornerRadius="4" HorizontalAlignment="Left" MinWidth="2">
                                            <Border.Background>
                                                <SolidColorBrush Color="#5B8DEF"/>
                                            </Border.Background>
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource PctToWidth}">
                                                    <Binding Path="Percentage"/>
                                                    <Binding Path="ActualWidth" ElementName="CatTrack"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="Топ категорій за витраченим часом" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12"/>

                    <ItemsControl ItemsSource="{Binding TopCategoriesByTime}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="10" Height="10" CornerRadius="3" Background="{Binding Color}" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Label}" FontSize="12" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="90"/>
                                    </StackPanel>

                                    <Border x:Name="TopCatTrack" Grid.Column="1" Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="4" Height="18" Margin="6,0">
                                        <Border CornerRadius="4" HorizontalAlignment="Left" MinWidth="2" Opacity="0.85">
                                            <Border.Background>
                                                <SolidColorBrush Color="#10B981"/>
                                            </Border.Background>
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource PctToWidth}">
                                                    <Binding Path="Percentage"/>
                                                    <Binding Path="ActualWidth" ElementName="TopCatTrack"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Border>

                                    <TextBlock Grid.Column="2" Text="{Binding DisplayValue}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Поки немає даних про витрачений час. Використовуйте таймер для відстеження часу."
                               FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" FontStyle="Italic" Margin="0,8,0,0"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TopCategoriesByTime.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
