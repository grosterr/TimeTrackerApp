<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WpfApp1.Views" 
        xmlns:viewmodels="clr-namespace:WpfApp1.ViewModels"
        xmlns:controls="clr-namespace:WpfApp1.Controls"
        xmlns:dd="urn:gong-wpf-dragdrop"
        Title="Smart Calendar" Height="1024" Width="1024" MinHeight="1024" MinWidth="1024">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{DynamicResource OverlayBackgroundBrush}" Visibility="{Binding IsMenuVisible, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="10,15,10,0">
                <TextBlock Text="Мій робочий простір" FontWeight="Bold" FontSize="16" Margin="5,0,0,15" Foreground="{DynamicResource PrimaryTextBrush}"/>
                <Button Content="📅 Календар" Command="{Binding ShowCalendarCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,5" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Foreground="{DynamicResource PrimaryTextBrush}"/>
                <Button Content="📋 Канбан-дошка" Command="{Binding ShowKanbanCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,5" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Foreground="{DynamicResource PrimaryTextBrush}"/>
                <Button Content="⏱ Таймер" Command="{Binding ShowTimerCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,5" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Foreground="{DynamicResource PrimaryTextBrush}"/>
                <Button Content="📊 Аналітика" Command="{Binding ShowAnalyticsCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,5" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Foreground="{DynamicResource PrimaryTextBrush}"/>
                <Button Content="📝 + Нова сторінка" Command="{Binding AddPageCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,15" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Foreground="{DynamicResource PrimaryTextBrush}"/>
                <Button Content="🌓 Змінити тему" Command="{Binding ToggleThemeCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,15" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Foreground="{DynamicResource PrimaryTextBrush}"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="10,10,10,10">
                <TextBlock Text="Швидкий огляд" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}" Margin="5,0,0,5"/>
                <controls:SafeCalendar x:Name="MiniCalendar" SelectedDate="{Binding SelectedDate}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent"/>
            </StackPanel>

            <Grid Grid.Row="2" Margin="10,0,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Мої Нотатки" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}" Margin="5,0,0,5" Grid.Row="0"/>
                <ListView Grid.Row="1" ItemsSource="{Binding Tasks}" SelectedItem="{Binding SelectedTask}" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch" dd:DragDrop.IsDragSource="True">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="5,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4" TextTrimming="CharacterEllipsis"/>

                                    <StackPanel Orientation="Horizontal">
                                        <Border CornerRadius="8" Padding="6,2" Margin="0,0,5,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#E0E0E0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="В процесі">
                                                            <Setter Property="Background" Value="#FFF4CE"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Виконано">
                                                            <Setter Property="Background" Value="#DFF6DD"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Заблоковано">
                                                            <Setter Property="Background" Value="#FDE7E9"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="Bold" Foreground="#333333"/>
                                        </Border>

                                        <Border CornerRadius="8" Padding="6,2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#E8F4FD"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Priority}" Value="Низький">
                                                            <Setter Property="Background" Value="#DFF6DD"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Priority}" Value="Високий">
                                                            <Setter Property="Background" Value="#FFF4CE"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Priority}" Value="Критичний">
                                                            <Setter Property="Background" Value="#FDE7E9"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Priority}" FontSize="10" FontWeight="Bold" Foreground="#333333"/>
                                        </Border>
                                    </StackPanel>

                                    <ItemsControl ItemsSource="{Binding TagList}" Margin="0,5,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="6" Padding="6,2" Margin="0,0,4,4">
                                                    <TextBlock Text="{Binding}" FontSize="9" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>

        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type viewmodels:LoginViewModel}">
                    <views:LoginView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type viewmodels:TaskEditorViewModel}">
                    <views:TaskEditorView />
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:CalendarViewModel}">
                    <views:CalendarView />
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:TimeTrackerViewModel}">
                    <views:TimeTrackerView />
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:KanbanViewModel}">
                    <views:KanbanView />
                </DataTemplate>



                <DataTemplate DataType="{x:Type viewmodels:AnalyticsViewModel}">
                    <views:AnalyticsView />
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>