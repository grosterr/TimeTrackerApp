<UserControl x:Class="WpfApp1.Views.CalendarView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:dd="urn:gong-wpf-dragdrop"
      xmlns:local="clr-namespace:WpfApp1.Views"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:core="clr-namespace:WpfApp1.Core"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1000"
      Background="Transparent"
      Focusable="True">

    <b:Interaction.Behaviors>
        <core:FocusBehavior/>
    </b:Interaction.Behaviors>

    <UserControl.InputBindings>
        <KeyBinding Key="Left" Command="{Binding PreviousCommand}"/>
        <KeyBinding Key="Right" Command="{Binding NextCommand}"/>

        <KeyBinding Key="D1" Command="{Binding SetScaleCommand}" CommandParameter="1"/>
        <KeyBinding Key="D2" Command="{Binding SetScaleCommand}" CommandParameter="2"/>
        <KeyBinding Key="D3" Command="{Binding SetScaleCommand}" CommandParameter="3"/>
        <KeyBinding Key="D4" Command="{Binding SetScaleCommand}" CommandParameter="4"/>
        <KeyBinding Key="D5" Command="{Binding SetScaleCommand}" CommandParameter="5"/>
        <KeyBinding Key="D6" Command="{Binding SetScaleCommand}" CommandParameter="6"/>
        <KeyBinding Key="D7" Command="{Binding SetScaleCommand}" CommandParameter="7"/>
        <KeyBinding Key="D8" Command="{Binding SetScaleCommand}" CommandParameter="8"/>
        <KeyBinding Key="D9" Command="{Binding SetScaleCommand}" CommandParameter="9"/>

        <KeyBinding Key="NumPad1" Command="{Binding SetScaleCommand}" CommandParameter="1"/>
        <KeyBinding Key="NumPad2" Command="{Binding SetScaleCommand}" CommandParameter="2"/>
        <KeyBinding Key="NumPad3" Command="{Binding SetScaleCommand}" CommandParameter="3"/>
        <KeyBinding Key="NumPad4" Command="{Binding SetScaleCommand}" CommandParameter="4"/>
        <KeyBinding Key="NumPad5" Command="{Binding SetScaleCommand}" CommandParameter="5"/>
        <KeyBinding Key="NumPad6" Command="{Binding SetScaleCommand}" CommandParameter="6"/>
        <KeyBinding Key="NumPad7" Command="{Binding SetScaleCommand}" CommandParameter="7"/>
        <KeyBinding Key="NumPad8" Command="{Binding SetScaleCommand}" CommandParameter="8"/>
        <KeyBinding Key="NumPad9" Command="{Binding SetScaleCommand}" CommandParameter="9"/>
    </UserControl.InputBindings>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <Button Content="◀" Command="{Binding PreviousCommand}" Background="Transparent" BorderThickness="0" FontSize="18" Cursor="Hand" Foreground="{DynamicResource SecondaryTextBrush}"/>
                <Button Content="▶" Command="{Binding NextCommand}" Background="Transparent" BorderThickness="0" FontSize="18" Cursor="Hand" Foreground="{DynamicResource SecondaryTextBrush}" Margin="10,0,0,0"/>
                <TextBlock Text="{Binding MonthYearHeader}" FontSize="24" FontWeight="Bold" Margin="20,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center">
                <TextBlock Text="Масштаб (днів):" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold"/>
                <Button Content="1" Command="{Binding SetScaleCommand}" CommandParameter="1" Margin="2" Width="30" Height="30" Background="{DynamicResource PanelBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderThickness="0" Cursor="Hand"/>
                <Button Content="3" Command="{Binding SetScaleCommand}" CommandParameter="3" Margin="2" Width="30" Height="30" Background="{DynamicResource PanelBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderThickness="0" Cursor="Hand"/>
                <Button Content="5" Command="{Binding SetScaleCommand}" CommandParameter="5" Margin="2" Width="30" Height="30" Background="{DynamicResource PanelBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderThickness="0" Cursor="Hand"/>
                <Button Content="7" Command="{Binding SetScaleCommand}" CommandParameter="7" Margin="2" Width="30" Height="30" Background="{DynamicResource PanelBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,18,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ItemsControl Grid.Column="1" ItemsSource="{Binding Days}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource CardBackgroundBrush}" Padding="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,1,0,1">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DayName}" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DayNumber}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                    <Setter Property="Foreground" Value="#4A90E2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid Height="1440" Background="{DynamicResource WindowBackgroundBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ItemsControl ItemsSource="{Binding Hours}" Grid.ColumnSpan="2">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Height="60" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                                <TextBlock Text="{Binding}" Margin="5,2" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" VerticalAlignment="Top"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl Grid.Column="1" ItemsSource="{Binding Days}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0" Background="Transparent"
                                    dd:DragDrop.IsDropTarget="True"
                                    dd:DragDrop.DropHandler="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}">

                                <ItemsControl ItemsSource="{Binding Tasks}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas Background="Transparent"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Top" Value="{Binding CanvasTop}"/>
                                            <Setter Property="Canvas.Left" Value="0"/>
                                            <Setter Property="Width" Value="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type Canvas}}}"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Height="{Binding CanvasHeight}" 
                                                    Background="{Binding BackgroundColor}" 
                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                                                    CornerRadius="6" Margin="0,0,6,0" Padding="5" Cursor="Hand"
                                                    dd:DragDrop.IsDragSource="True">

                                                <Border.Effect>
                                                    <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="4" ShadowDepth="1"/>
                                                </Border.Effect>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding DueDate, StringFormat={}{0:HH:mm}}" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource PrimaryTextBrush}" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>

                                                    <Button Grid.Column="1" Content="✏️" 
                                                              Command="{Binding DataContext.EditTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              CommandParameter="{Binding}"
                                                              Background="{DynamicResource PanelBackgroundBrush}" BorderThickness="0" Cursor="Hand" 
                                                             VerticalAlignment="Top" Padding="2" FontSize="10" ToolTip="Редагувати нотатку"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>